{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Slack 대시보드",
  "version": "1.0.0",
  "identifier": "com.solbox.slackdashboard",
  "build": {
    "frontendDist": "../src",
    "devUrl": "http://localhost:1430",
    "beforeDevCommand": "node src-tauri/dev-server.cjs"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "Slack 대시보드",
        "width": 540,
        "height": 900,
        "minWidth": 360,
        "minHeight": 500,
        "center": true,
        "resizable": true,
        "decorations": true,
        "transparent": false,
        "alwaysOnTop": false,
        "fullscreen": false,
        "visible": true,
        "backgroundThrottling": "disabled"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis", "dmg", "app", "deb"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "shortDescription": "Slack을 카톡처럼 가볍게",
    "longDescription": "솔박스 직원용 경량 Slack 클라이언트 — 카톡 스타일 UI, 실시간 알림",
    "windows": {
      "nsis": {
        "installMode": "currentUser",
        "installerIcon": "icons/icon.ico"
      }
    }
  }
}
